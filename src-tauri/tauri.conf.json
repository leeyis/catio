{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Catio",
  "version": "0.4.0",
  "identifier": "io.catio.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [{
      "title": "Catio", "width": 1440, "height": 900, "minWidth": 1100, "minHeight": 640, "center": true,
      "decorations": false, "titleBarStyle": "Overlay", "transparent": false
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": { "resources/catio-jdbc-plugin.jar": "catio-jdbc-plugin.jar" }
  }
}
