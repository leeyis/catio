{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Catio",
  "version": "0.1.0",
  "identifier": "io.catio.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [{
      "title": "Catio", "width": 1440, "height": 900, "minWidth": 1100, "minHeight": 640, "center": true,
      "decorations": false, "titleBarStyle": "Overlay", "transparent": false
    }],
    "security": { "csp": null }
  },
  "bundle": { "active": true, "targets": "all", "icon": ["icons/icon.png", "icons/icon.ico"] }
}
